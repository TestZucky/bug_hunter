{
  "name": "bug-hunter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "gen:challenges": "tsx scripts/generate-challenges.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx scripts/db-seed.ts",
    "prepare": "husky",
    "challenges": "tsx scripts/challenges-admin.ts"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.11.1",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "next": "^15.5.20",
    "openai": "4.77.0",
    "pg": "^8.22.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "3.2.0",
    "zod": "3.24.1",
    "zustand": "5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.12",
    "@types/node": "22.10.7",
    "@types/pg": "^8.20.0",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@vitest/coverage-v8": "^3.2.7",
    "drizzle-kit": "^0.31.10",
    "eslint": "8.57.1",
    "eslint-config-next": "^15.5.20",
    "eslint-config-prettier": "9.1.0",
    "husky": "9.1.7",
    "lint-staged": "15.3.0",
    "prettier": "3.4.2",
    "tailwindcss": "4.1.12",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.7"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
