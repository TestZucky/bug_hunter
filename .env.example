# Copy this file to ".env" and fill in values. ".env" is git-ignored.

# Postgres connection (matches docker-compose.yml).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bughunter

# Optional: Redis for shared rate limiting + game sessions across instances.
# Without it, both fall back to in-memory (fine for a single instance / dev).
# REDIS_URL=redis://localhost:6379

# OpenAI key for the challenge generation pipeline.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Optional overrides:
# OPENAI_MODEL=gpt-4o
# OPENAI_VERIFY_MODEL=gpt-4o
# OPENAI_EMBED_MODEL=text-embedding-3-small
# DEDUP_SIM_THRESHOLD=0.9
